{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js",
          "!/chunk-*.js",
          "/assets/**",
          "!/assets/i18n/**",
          "!/assets/legal-i18n/**",
          "!/blocks/library_factory_export.txt"
        ]
      }
    },
    {
      "name": "modules-including-translations",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/chunk-*.js"
        ]
      }
    }
  ]
}
